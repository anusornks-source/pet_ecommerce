generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String
  phone     String?
  address   String?
  avatar    String?
  role      Role     @default(USER)
  active    Boolean  @default(true)
  provider  String?
  oauthId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart            Cart?
  orders          Order[]
  reviews         Review[]
  wishlists       Wishlist[]
  addresses       Address[]
  shopMemberships    ShopMember[]
  nicheKeywords      NicheKeyword[]
  nicheKeywordFocuses NicheKeywordFocus[]
  painPoints         PainPoint[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]

  @@unique([provider, oauthId])
  @@map("users")
}

// ─── Multi-Shop Models ────────────────────────────────────────

model Shop {
  id             String   @id @default(cuid())
  name           String
  name_th        String?
  slug           String   @unique
  description    String?
  description_th String?
  logoUrl        String?
  coverUrl       String?
  usePetType     Boolean  @default(true)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members        ShopMember[]
  settings       ShopSettings?
  shopCategories ShopCategory[]
  products       Product[]
  heroBanners    HeroBanner[]
  shelves        Shelf[]
  articles       Article[]
  coupons        Coupon[]
  orders         Order[]
  tags           Tag[]
  cjApiLogs      CjApiLog[]
  stores           Store[]
  painPoints       PainPoint[]
  trendCandidates  TrendCandidate[]
  marketingAssets  MarketingAsset[]
  /// ลำดับ marketing assets เมื่อดูที่หน้าร้าน (asset IDs)
  marketingAssetOrder String[] @default([])

  @@map("shops")
}

enum ShopRole {
  OWNER
  MANAGER
  STAFF
}

model ShopMember {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  role      ShopRole @default(STAFF)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@map("shop_members")
}

model ShopSettings {
  id                    String    @id @default(cuid())
  shopId                String    @unique
  promptpayId           String?
  bankName              String?
  bankAccount           String?
  bankAccountName       String?
  adminEmail            String?
  useGlobalPayment      Boolean   @default(true)
  stripeSecretKey       String?
  stripePublishableKey  String?
  stripeWebhookSecret   String?
  cjAccessToken         String?
  cjTokenExpiresAt      DateTime?
  cjPriceFactor         Float     @default(3)
  usdToThb              Float     @default(36)
  displayStockMin       Int       @default(50)
  displayStockMax       Int       @default(100)
  primaryColor          String    @default("#f97316")
  secondaryColor        String    @default("#f59e0b")
  bgColor               String    @default("#ffffff")
  phone                 String?
  lineId                String?
  facebookUrl           String?
  instagramUrl          String?
  tiktokUrl             String?
  announcementText      String?
  announcementEnabled   Boolean   @default(false)
  shippingFee           Float     @default(0)
  freeShippingMin       Float     @default(0)
  updatedAt             DateTime  @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shop_settings")
}

model ShopCategory {
  id         String @id @default(cuid())
  shopId     String
  categoryId String

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([shopId, categoryId])
  @@map("shop_categories")
}

// ─── Taxonomy (Global) ────────────────────────────────────────

model CategoryGroup {
  id         String     @id @default(cuid())
  name       String     @unique
  name_th    String?
  slug       String     @unique
  icon       String?
  order      Int        @default(0)
  categories Category[]

  @@map("category_groups")
}

model Category {
  id             String         @id @default(cuid())
  name           String         @unique
  name_th        String?
  slug           String         @unique
  icon           String?
  order          Int            @default(0)
  groupId        String?
  group          CategoryGroup? @relation(fields: [groupId], references: [id])
  products       Product[]
  shopCategories ShopCategory[]

  @@map("categories")
}

model PetType {
  id       String    @id @default(cuid())
  name     String    @unique
  name_th  String?
  slug     String    @unique
  icon     String?
  order    Int       @default(0)
  products Product[]

  @@map("pet_types")
}

// ─── Products ─────────────────────────────────────────────────

model Product {
  id                  String   @id @default(cuid())
  name                String
  name_th             String?
  description         String
  description_th      String?
  shortDescription    String?
  shortDescription_th String?
  price               Float
  normalPrice         Float?
  stock       Int      @default(0)
  images      String[]
  videos      String[] @default([])
  /// ลำดับแสดงผลรวม (images + videos ปนกัน) — ถ้าว่างใช้ [...images, ...videos]
  mediaOrder  String[] @default([])
  categoryId  String
  petTypeId   String?
  shopId      String
  active          Boolean  @default(true)
  featured        Boolean  @default(false)
  cjProductId         String?
  costPrice           Float?
  source              String?
  fulfillmentMethod   FulfillmentMethod   @default(SELF)
  sourceDescription   String?
  sourceData          Json?
  deliveryDays        Int       @default(2)
  warehouseCountry    String?
  createdAt       DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop       Shop             @relation(fields: [shopId], references: [id])
  category   Category         @relation(fields: [categoryId], references: [id])
  petType    PetType?         @relation(fields: [petTypeId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]
  wishlists  Wishlist[]
  variants   ProductVariant[]
  shelfItems     ShelfItem[]
  tags           Tag[]                  @relation("ProductTags")
  marketingPacks   ProductMarketingPack[]
  trendCandidate   TrendCandidate?
  marketingAssets  MarketingAsset[]
  /// ลำดับ marketing assets เมื่อดูที่หน้าสินค้า (asset IDs)
  marketingAssetOrder String[] @default([])

  @@index([shopId])
  @@index([shopId, active])
  @@index([shopId, categoryId])
  @@index([shopId, petTypeId])
  @@index([shopId, source])
  @@index([shopId, active, createdAt])
  @@index([shopId, active, price])
  @@index([shopId, active, stock])
  @@index([shopId, active, name])
  @@index([active, createdAt])
  @@index([active, featured])
  @@map("products")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  size      String?
  color     String?
  price     Float
  stock     Int      @default(0)
  cjStock   Int?
  sku       String?
  cjVid             String?
  variantImage      String?
  attributes        Json?
  active            Boolean  @default(true)
  fulfillmentMethod FulfillmentMethod?
  createdAt    DateTime @default(now())

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variants")
}

model ProductMarketingPack {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  lang           String   @default("th")
  productName    String
  name           String?  /// ชื่อที่แก้ไขได้ (แสดงแทน productName ถ้ามี)
  note           String?  @db.Text
  hooks              Json
  captionFacebook    String?  @db.Text
  captionInstagram   String?  @db.Text
  captionLine        String?  @db.Text
  adAngles           Json
  ugcScript      String   @db.Text
  thumbnailTexts Json
  imageAdPrompts Json?
  videoAdPrompts Json?
  rawHooks       String?  @db.Text
  rawCaptions    String?  @db.Text
  rawAngles      String?  @db.Text
  rawUgc         String?  @db.Text
  rawThumbnails  String?  @db.Text
  rawImagePrompts String? @db.Text
  rawVideoPrompts String? @db.Text
  createdAt      DateTime @default(now())
  /// ลำดับ marketing assets เมื่อดูที่ pack นี้ (asset IDs)
  marketingAssetOrder String[] @default([])

  marketingAssets MarketingAsset[]

  @@index([productId])
  @@map("product_marketing_packs")
}

enum MarketingAssetType {
  IMAGE
  VIDEO
  PDF
}

model MarketingAsset {
  id              String             @id @default(cuid())
  url             String
  type            MarketingAssetType
  name            String?            /// ชื่อที่ user ตั้งเอง
  filename        String?
  contentType     String?
  sizeBytes       Int?
  width           Int?
  height          Int?
  shopId          String?
  productId       String?
  marketingPackId String?
  prompt          String?  @db.Text
  angle           String?
  note            String?  @db.Text
  sortOrder       Int?
  createdAt       DateTime @default(now())

  shop           Shop?                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product        Product?              @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketingPack  ProductMarketingPack? @relation(fields: [marketingPackId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([productId])
  @@index([marketingPackId])
  @@map("marketing_assets")
}

// ─── Customer ─────────────────────────────────────────────────

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("บ้าน")
  name      String
  phone     String
  address   String
  city      String?
  province  String?
  zipCode   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@map("reviews")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int     @default(1)

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@map("cart_items")
}

// ─── Orders ───────────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  userId        String
  shopId        String
  status        OrderStatus @default(PENDING)
  total         Float
  discount      Float       @default(0)
  couponCode    String?
  address       String
  city          String?
  province      String?
  zipCode       String?
  phone         String
  note          String?
  statusHistory    Json?
  stripeSessionId  String?
  cjOrderId        String?
  cjStatus        String?
  trackingNumber      String?
  trackingCarrier     String?
  selfTrackingNumber  String?
  selfTrackingCarrier String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id])
  shop      Shop        @relation(fields: [shopId], references: [id])
  items     OrderItem[]
  payment   Payment?
  cjApiLogs CjApiLog[]

  @@index([shopId])
  @@index([shopId, status])
  @@index([shopId, createdAt])
  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  variantId    String?
  quantity     Int
  price        Float
  productName       String?
  variantLabel      String?
  source            String?
  fulfillmentMethod String?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  amount    Float
  ref       String?
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── Enums ────────────────────────────────────────────────────

enum FulfillmentMethod {
  SELF
  CJ
  SUPPLIER
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  PROMPTPAY
  COD
  STRIPE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENT
  FIXED
}

// ─── Site & Content ───────────────────────────────────────────

model SiteSettings {
  id              String   @id @default("default")
  storeName       String   @default("PetShop")
  logoUrl         String?
  heroImageUrl    String?
  homeHeroTitle      String?
  homeHeroSubtitle   String?
  adminEmail      String?
  promptpayId     String?
  bankName        String?
  bankAccount     String?
  bankAccountName  String?
  cjAccessToken    String?
  cjTokenExpiresAt DateTime?
  cjPriceFactor    Float    @default(3)
  usdToThb         Float    @default(36)
  displayStockMin       Int       @default(50)
  displayStockMax       Int       @default(100)
  thaiAddressUpdatedAt  DateTime?
  thaiAddressBlobUrl    String?
  updatedAt             DateTime  @updatedAt

  @@map("site_settings")
}

model HeroBanner {
  id                   String   @id @default(cuid())
  shopId               String
  imageUrl             String
  badge                String?
  badge_th             String?
  title                String?
  title_th             String?
  titleHighlight       String?
  titleHighlight_th    String?
  subtitle             String?
  subtitle_th          String?
  ctaLabel             String?
  ctaLabel_th          String?
  ctaUrl               String?
  secondaryCtaLabel    String?
  secondaryCtaLabel_th String?
  secondaryCtaUrl      String?
  feat1Enabled         Boolean  @default(true)
  feat1Icon            String?  @default("✅")
  feat1Label           String?  @default("Quality Products")
  feat1Label_th        String?  @default("สินค้าคุณภาพ")
  feat2Enabled         Boolean  @default(true)
  feat2Icon            String?  @default("🚚")
  feat2Label           String?  @default("Nationwide Shipping")
  feat2Label_th        String?  @default("จัดส่งทั่วไทย")
  feat3Enabled         Boolean  @default(true)
  feat3Icon            String?  @default("💬")
  feat3Label           String?  @default("After Sales")
  feat3Label_th        String?  @default("ดูแลหลังขาย")
  order                Int      @default(0)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@map("hero_banners")
}

model Article {
  id         String   @id @default(cuid())
  shopId     String
  title      String
  title_th   String?
  slug       String   @unique
  excerpt    String?
  excerpt_th String?
  content    String
  content_th String?
  coverImage String?
  published  Boolean  @default(false)
  tags       String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@map("articles")
}

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String
  phone     String
  openHours String
  image     String?
  remark    String?
  lat       Float
  lng       Float
  shopId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop? @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@map("stores")
}

model CjApiLog {
  id        String   @id @default(cuid())
  orderId   String?
  shopId    String?
  action    String
  request   Json?
  response  Json?
  success   Boolean
  error     String?
  createdAt DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id])
  shop  Shop?  @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([shopId, createdAt])
  @@map("cj_api_logs")
}

model Coupon {
  id        String     @id @default(cuid())
  shopId    String
  code      String     @unique
  type      CouponType
  value     Float
  minOrder  Float?
  maxUses   Int?
  usedCount Int        @default(0)
  active    Boolean    @default(true)
  expiresAt DateTime?
  createdAt DateTime   @default(now())

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@map("coupons")
}

model ProcessedStripeEvent {
  id        String   @id
  createdAt DateTime @default(now())

  @@map("processed_stripe_events")
}

// ─── Auth Tokens ─────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model Shelf {
  id          String      @id @default(cuid())
  shopId      String
  name        String
  slug        String      @unique
  description String?
  color       String      @default("#0ea5e9")
  active      Boolean     @default(true)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       ShelfItem[]

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([shopId, active])
  @@map("shelves")
}

model ShelfItem {
  id        String  @id @default(cuid())
  shelfId   String
  productId String
  order     Int     @default(0)

  shelf   Shelf   @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([shelfId, productId])
  @@map("shelf_items")
}

model Tag {
  id        String    @id @default(cuid())
  shopId    String?
  name      String
  nameEn    String?
  slug      String    @unique
  color     String    @default("orange")
  icon      String?
  products  Product[] @relation("ProductTags")
  createdAt DateTime  @default(now())

  shop Shop? @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@map("tags")
}

model ApiLog {
  id         String   @id @default(cuid())
  type       String
  source     String?
  method     String?
  path       String
  statusCode Int?
  userId     String?
  eventType  String?
  eventId    String?
  request    Json?
  response   Json?
  duration   Int?
  success    Boolean  @default(true)
  error      String?
  ip         String?
  createdAt  DateTime @default(now())

  @@map("api_logs")
}

enum PlatformSource {
  TIKTOK
  SHOPEE
  FACEBOOK
  INSTAGRAM
  LINE
  LAZADA
  MANUAL
}

model TrendCandidate {
  id              String         @id @default(cuid())
  shopId          String?
  platformSource  PlatformSource @default(TIKTOK)
  productName     String
  productImage    String?
  category        String?
  sourceUrl       String?
  salesVolume     String?
  trendScore      Float?
  marketFit       Float?
  marginPotential Float?
  competition     Float?
  overallScore    Float?
  aiAnalysis      String?  @db.Text
  status          String   @default("pending")

  name_th             String?
  description         String?  @db.Text
  description_th      String?  @db.Text
  suggestedCategory   String?
  suggestedPetType    String?
  suggestedPrice      Float?
  nicheKeyword        String?

  productId       String?  @unique
  scrapedAt       DateTime?
  scoredAt        DateTime?
  approvedAt      DateTime?
  enrichedAt      DateTime?
  importedAt      DateTime?
  createdAt       DateTime @default(now())

  shop    Shop?    @relation(fields: [shopId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([shopId])
  @@index([status])
  @@index([platformSource])
  @@index([overallScore])
  @@map("trend_candidates")
}

model PainPoint {
  id                 String   @id @default(cuid())
  shopId             String?
  category           String
  painPoint          String   @db.Text
  painPoint_th       String?  @db.Text
  severity           String
  productOpportunity String   @db.Text
  nicheKeyword       String
  shopCanSolve       Boolean  @default(false)
  createdById        String?
  createdAt          DateTime @default(now())

  shop          Shop?          @relation(fields: [shopId], references: [id])
  createdBy     User?          @relation(fields: [createdById], references: [id])
  nicheKeywords NicheKeyword[]

  @@index([shopId])
  @@map("pain_points")
}

model NicheKeyword {
  id          String   @id @default(cuid())
  niche       String
  niche_th    String?
  type        String   @default("manual")
  reason      String?
  reason_th   String?
  remark            String?
  aiRecommendation  String?
  tags              String[]
  painPointId       String?
  createdById String?
  createdBy   User?      @relation(fields: [createdById], references: [id])
  painPoint   PainPoint? @relation(fields: [painPointId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  focuses     NicheKeywordFocus[]

  @@unique([niche])
  @@index([painPointId])
  @@map("niche_keywords")
}

model NicheKeywordFocus {
  id             String       @id @default(cuid())
  userId         String
  nicheKeywordId String
  note           String?
  user           User         @relation(fields: [userId], references: [id])
  nicheKeyword   NicheKeyword @relation(fields: [nicheKeywordId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, nicheKeywordId])
  @@map("niche_keyword_focuses")
}
